DATAFLOW_BASE_URL=https://your-dataflow-api-host.example.com
DATAFLOW_API_KEY=your-api-key
# Leave empty if the key value should be sent directly as Authorization.
# Use Bearer or Token if your Dataflow key requires a scheme.
DATAFLOW_AUTH_SCHEME=

# Just One API - Xiaohongshu Pugongying creator search.
JUSTONE_API_BASE_URL=https://api.justoneapi.com
JUSTONE_API_TOKEN=your-justoneapi-token
JUSTONE_API_TIMEOUT=60

# TikHub - Xiaohongshu Web V3 fetch user info.
# Docs: https://docs.tikhub.io/438852177e0
# GET /api/v1/xiaohongshu/web_v3/fetch_user_info?user_id=<xhs_user_id>
# Authorization: Bearer <token>
TIKHUB_API_BASE_URL=https://api.tikhub.io
TIKHUB_API_TOKEN=your-tikhub-token
TIKHUB_API_TIMEOUT=60

# Local report generation source database. Runtime demo reads static frontend/public/demo-track-reports.json.
REPORT_MYSQL_HOST=127.0.0.1
REPORT_MYSQL_PORT=3306
REPORT_MYSQL_DATABASE=media_crawler
REPORT_MYSQL_USER=crawler
REPORT_MYSQL_PASSWORD=your-mysql-password

# OpenAI-compatible relay for regenerating demo reports.
AI_BASE_URL=https://your-ai-relay.example.com/v1
AI_API_KEY=your-ai-api-key
AI_MODEL=your-model-name
AI_TIMEOUT=60
